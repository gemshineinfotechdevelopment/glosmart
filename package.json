    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.23.0",
    "mongoose": "^9.7.4",
    "multer": "^2.2.0",
    "multer-storage-cloudinary": "^4.0.0",
    "razorpay": "^2.9.8",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-easy-crop": "^6.2.2",
    "react-icons": "^5.7.0",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.2",
