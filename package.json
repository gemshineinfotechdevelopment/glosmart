  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "frontend": "npm run dev",
    "backend": "npm run dev:backend",
    "dev:backend": "cd server && npm run dev",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:backend\"",
